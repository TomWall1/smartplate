# Copy this file to .env and fill in your API keys

# Spoonacular Recipe API
# Get your key from: https://spoonacular.com/food-api/console
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# Coles Product API (RapidAPI)
# Get your key from: https://rapidapi.com/data-holdings-group-data-holdings-group-default/api/coles-product-price-api
COLES_API_KEY=your_rapidapi_key_here

# Woolworths API (not yet available - placeholder)
WOOLWORTHS_API_KEY=not_available_yet

# Server Port
PORT=3001

# Database (for future use)
# DATABASE_URL=postgres://username:password@localhost:5432/smartplate

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (auth + user profiles)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key — required for admin routes (bypasses RLS). Keep secret!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin email — this user gets access to /admin dashboard
ADMIN_EMAIL=your_admin_email@example.com