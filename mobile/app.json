{
  "expo": {
    "name": "Deal to Dish",
    "slug": "deals-to-dish",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EEE2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smartplate.dealstodish",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#36453B"
      },
      "package": "com.smartplate.dealstodish"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "dealstodish",
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.TODO_IOS_CLIENT_ID"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://deals-to-dish-api.onrender.com"
    }
  }
}
